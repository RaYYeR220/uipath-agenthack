# UiPath Orchestrator — live target invocation (used by: sentinel audit --target uipath)
# Copy this file to ".env" (which is gitignored) and fill in the blanks.
# Do NOT commit real secrets.

# Base Orchestrator URL. Pattern: https://cloud.uipath.com/{org}/{tenant}/orchestrator_
# (org/tenant are visible in your Orchestrator browser URL; ours look like hackathon26_614 / DefaultTenant)
UIPATH_BASE_URL=https://cloud.uipath.com/hackathon26_614/DefaultTenant/orchestrator_

# Identity (token) endpoint — default is correct for UiPath Automation Cloud
UIPATH_IDENTITY_URL=https://cloud.uipath.com/identity_

# External Application (Confidential) credentials — Admin → External Applications
# Required scopes: OR.Jobs OR.Execution OR.Folders
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# Folder where LoanAdvisor was deployed. The Solutions deploy wizard creates a subfolder,
# so this is typically "Shared/LoanAdvisor" (confirm the exact name after deploy).
UIPATH_FOLDER_PATH=Shared/LoanAdvisor

# OAuth scope (default shown; usually leave as-is)
UIPATH_SCOPE=OR.Jobs OR.Execution OR.Folders
