# Sentinel — live run config. Copy this file to ".env" (gitignored) and fill in
# UIPATH_CLIENT_ID / UIPATH_CLIENT_SECRET. The CLI auto-loads .env, so once filled:
#
#   uv run sentinel audit --target uipath --llm uipath \
#       --testmanager-project Sentinel-LoanAdvisor-Audit --out report
#
# Validated 2026-06-11 against the AgentHack staging org.

# --- Orchestrator (agent invocation via Jobs API) ---
# Base pattern: https://{host}/{org}/{tenant}/orchestrator_  (this org is on STAGING)
UIPATH_BASE_URL=https://staging.uipath.com/hackathon26_614/DefaultTenant/orchestrator_
UIPATH_IDENTITY_URL=https://staging.uipath.com/identity_

# External Application (Confidential) credentials — Admin -> External Applications.
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# OAuth scopes. Orchestrator resource: OR.Jobs OR.Execution OR.Folders.
# Test Manager resource: TM.TestCases TM.TestSets TM.TestExecutions TM.Projects.Read.
UIPATH_SCOPE=OR.Jobs OR.Execution OR.Folders TM.TestCases TM.TestSets TM.TestExecutions TM.Projects.Read

# Folder where the LoanAdvisor agent solution was deployed (deploy wizard subfolder).
UIPATH_FOLDER_PATH=Shared/Solution

# ProcessKey of the deployed agent (note the "Solution.agent." prefix from the solution).
UIPATH_PROCESS_KEY=Solution.agent.LoanAdvisor

# --- Governed LLM judge (UiPath AI Trust Layer gateway, --llm uipath) ---
# Model id from the org's AI Trust Layer catalog. gpt-4.1-mini is fast+cheap;
# anthropic.claude-sonnet-4-6 is a stronger judge.
UIPATH_LLM_MODEL=gpt-4.1-mini-2025-04-14
