# UiPath Orchestrator — live target invocation (used by: sentinel audit --target uipath)
# Copy this file to ".env" (which is gitignored) and fill in the blanks.
# Do NOT commit real secrets.
#
# VALIDATED 2026-06-11 against the AgentHack staging org (live end-to-end OK).

# Base Orchestrator URL. Pattern: https://{host}/{org}/{tenant}/orchestrator_
# NOTE: the AgentHack org is on STAGING (staging.uipath.com), not cloud.uipath.com.
UIPATH_BASE_URL=https://staging.uipath.com/hackathon26_614/DefaultTenant/orchestrator_

# Identity (token) endpoint — must match the host above (staging).
UIPATH_IDENTITY_URL=https://staging.uipath.com/identity_

# External Application (Confidential) credentials — Admin → External Applications
# Required scopes: OR.Jobs OR.Execution OR.Folders
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# Folder where LoanAdvisor was deployed. The Solutions deploy wizard created the
# subfolder "Solution" under Shared.
UIPATH_FOLDER_PATH=Shared/Solution

# OAuth scope (default shown; usually leave as-is)
UIPATH_SCOPE=OR.Jobs OR.Execution OR.Folders

# Process key to pass as: sentinel audit --target uipath --process-key Solution.agent.LoanAdvisor
# (the deployed release's ProcessKey is "Solution.agent.LoanAdvisor", not just "LoanAdvisor")
